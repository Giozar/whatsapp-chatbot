# API KEY para usar modelos de la nube
OPENAI_API_KEY=sk-1234567890abcdef1234567890abcdef
GROQ_API_KEY=gsk_1234567890abcdef1234567890abcdef

# Transcripción de audios: 'local' (Whisper descargado, corre en tu máquina)
# o 'groq' (Whisper vía API de Groq, requiere GROQ_API_KEY)
TRANSCRIPTION_PROVIDER=local

# Modelo Whisper para modo local (se descarga a storage/models/ la primera vez)
# Opciones: Xenova/whisper-tiny | Xenova/whisper-base | Xenova/whisper-small | Xenova/whisper-medium
WHISPER_MODEL=Xenova/whisper-small

# Configuración del modelo de IA local (Ollama)
# Nombre del modelo a usar. Debe estar disponible en tu instancia de Ollama.
# Ejemplos: llama3.2:latest | mistral:latest | gemma4:latest
AI_MODEL=llama3.2:latest

# Indica si el modelo fue creado con un Modelfile personalizado de Ollama.
# Usa 'true' si definiste el modelo con un Modelfile; 'false' en caso contrario.
USES_MODELFILE=false