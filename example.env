# =========================
# Configuracion general
# =========================
PORT=3008

# Modo para el motor de texto:
# - local: usa Ollama en tu maquina
# - cloud: usa un proveedor por API
LLM_MODE=local

# Modo para voz:
# - local: usa Whisper descargado localmente
# - cloud: usa Groq Whisper por API
VOICE_MODE=local

# =========================
# LLM local
# Requiere LLM_MODE=local
# =========================
# Puedes dejar LLM_PROVIDER=ollama para que la intencion quede explicita
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# Si el modelo local fue creado desde un Modelfile y ya trae instrucciones
USES_MODELFILE=false

# =========================
# LLM cloud
# Requiere LLM_MODE=cloud
# LLM_PROVIDER debe ser openai o groq
# =========================
OPENAI_API_KEY=sk-1234567890abcdef1234567890abcdef
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=gsk_1234567890abcdef1234567890abcdef
GROQ_MODEL=llama-3.3-70b-versatile

# =========================
# Vision / media
# =========================
# Si esta en false, imagenes y stickers reciben una respuesta controlada.
# No se valida ni se lee ninguna otra variable de vision.
VISION_ENABLED=true

# true: usa el LLM de texto activo (OLLAMA_MODEL / OPENAI_MODEL / GROQ_MODEL).
#       El modelo elegido debe ser multimodal.
# false: configura un modelo de vision separado con las variables de abajo.
VISION_MODEL_MULTIMODAL=true

# --- Solo si VISION_MODEL_MULTIMODAL=false ---

# Modo del modelo de vision: local | cloud
VISION_MODE=local

# Si VISION_MODE=local (usa OLLAMA_HOST del bloque local de arriba):
VISION_LOCAL_MODEL=gemma4:e4b

# Si VISION_MODE=cloud (puede ser un proveedor distinto al LLM de texto):
VISION_CLOUD_PROVIDER=groq       # openai | groq
VISION_CLOUD_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VISION_CLOUD_API_KEY=gsk_1234567890abcdef1234567890abcdef

# =========================
# Voz local
# Requiere VOICE_MODE=local
# El modelo se descargara en el primer uso
# =========================
TRANSCRIPTION_PROVIDER=local
WHISPER_MODEL=Xenova/whisper-small

# =========================
# Voz cloud
# Requiere VOICE_MODE=cloud
# Actualmente usa Groq para transcripcion
# =========================
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# =========================
# Storage y runtime local
# =========================
AUDIO_STORAGE_DIR=storage/audios
MEDIA_STORAGE_DIR=storage/media
MODEL_CACHE_DIR=storage/models

# Delay aleatorio para enviar respuestas por chunks
REPLY_MIN_DELAY_MS=3000
REPLY_MAX_DELAY_MS=15000

# =========================
# Historial de conversacion
# =========================
# Activa o desactiva el resumen automatico cuando el historial crece
HISTORY_SUMMARY_ENABLED=true
# Numero de mensajes que dispara el resumen (debe ser mayor a HISTORY_KEEP_RECENT)
HISTORY_MAX_MESSAGES=20
# Mensajes literales que se conservan despues del resumen
HISTORY_KEEP_RECENT=8
# Imprime el historial completo en consola en cada mensaje
HISTORY_LOG_ENABLED=true

# =========================
# Persistencia de conversacion
# =========================
# Persiste el historial en disco para sobrevivir reinicios.
# false: solo en memoria (comportamiento previo, se pierde al reiniciar).
CONVERSATION_PERSIST_ENABLED=true
# Backend de almacenamiento: file (futuro: memory | db)
CONVERSATION_STORE=file
# Carpeta donde se guarda un JSON por usuario
CONVERSATION_STORAGE_DIR=storage/conversations
# Cantidad de mensajes recientes a restaurar al retomar una conversacion (la N)
CONVERSATION_RESTORE_MESSAGES=10
