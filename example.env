# =========================
# Configuracion general
# =========================
PORT=3008

# Modo para el motor de texto:
# - local: usa Ollama en tu maquina
# - cloud: usa un proveedor por API
LLM_MODE=local

# Modo para voz:
# - local: usa Whisper descargado localmente
# - cloud: usa Groq Whisper por API
VOICE_MODE=local

# =========================
# LLM local
# Requiere LLM_MODE=local
# =========================
# Puedes dejar LLM_PROVIDER=ollama para que la intencion quede explicita
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# Alias legacy soportado por compatibilidad.
# Preferir OLLAMA_MODEL para configuraciones nuevas.
AI_MODEL=llama3.2:latest

# Si el modelo local fue creado desde un Modelfile y ya trae instrucciones
USES_MODELFILE=false

# =========================
# LLM cloud
# Requiere LLM_MODE=cloud
# LLM_PROVIDER debe ser openai o groq
# =========================
OPENAI_API_KEY=sk-1234567890abcdef1234567890abcdef
OPENAI_MODEL=gpt-4o-mini

GROQ_API_KEY=gsk_1234567890abcdef1234567890abcdef
GROQ_MODEL=llama-3.3-70b-versatile

# =========================
# Voz local
# Requiere VOICE_MODE=local
# El modelo se descargara en el primer uso
# =========================
TRANSCRIPTION_PROVIDER=local
WHISPER_MODEL=Xenova/whisper-small

# =========================
# Voz cloud
# Requiere VOICE_MODE=cloud
# Actualmente usa Groq para transcripcion
# =========================
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# =========================
# Storage y runtime local
# =========================
AUDIO_STORAGE_DIR=storage/audios
MODEL_CACHE_DIR=storage/models

# Delay aleatorio para enviar respuestas por chunks
REPLY_MIN_DELAY_MS=3000
REPLY_MAX_DELAY_MS=15000
